# ============================================================================
# Copy this file to ".env" and fill in OPENAI_API_KEY before running.
#   cp .env.example .env        (Linux/Mac)
#   Copy-Item .env.example .env (PowerShell)
# ============================================================================

# --- App ---
APP_NAME=InsightFlow AI
ENVIRONMENT=development

# --- Database (service name "postgres" resolves inside the docker network) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/insightflow_ai

# --- Redis: db0 = Celery broker, db1 = results, db2 = rate-limit buckets, db3 = cache ---
REDIS_URL=redis://redis:6379/3
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
RATELIMIT_REDIS_URL=redis://redis:6379/2

# --- JWT (this secret MUST match the one in kong/kong.yml) ---
JWT_SECRET=change-me-in-prod-super-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=insightflow-ai
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Local storage shared by API and workers ---
LOCAL_STORAGE_PATH=storage_data

# --- Kafka (event backbone) ---
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=insightflow.events

# --- OpenAI: website analysis uses the web search tool ---
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o
# Tool type for web search. Use "web_search_preview" or "web_search" depending on your SDK/account.
OPENAI_SEARCH_TOOL=web_search
OPENAI_REQUEST_TIMEOUT=120
# Set true for local demos without calling OpenAI or spending API credits.
OPENAI_MOCK=false

# --- LLM backpressure: gate around the PROVIDER's limits, not your CPU ---
# Requests/minute budget shared across all AI workers (token bucket in Redis).
LLM_MAX_RPM=60
# Concurrency is enforced by the AI worker's -c flag (see docker-compose.yml).
LLM_MAX_CONCURRENCY=20

# --- Scraping politeness: per-domain request rate (requests/second) ---
SCRAPE_PER_DOMAIN_RPS=1.0
SCRAPE_TIMEOUT=20
SCRAPE_USER_AGENT=InsightFlowAIBot/1.0 (+http://localhost)
